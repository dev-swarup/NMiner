{
    "name": "nminer",
    "main": "index.js",
    "version": "1.2.13",
    "typings": "index.d.ts",
    "description": "NMiner is a silent, high performance, open source, cross platform RandomX CPU miner. Official binaries are available for Windows and Linux.",
    "exports": {
        ".": {
            "types": "./index.d.ts",
            "default": "./index.js"
        },
        "./miner": {
            "types": "./src/js/miner.d.ts",
            "default": "./src/js/miner.js"
        }
    },
    "scripts": {
        "tsc": "tsc",
        "build": "cmake-js -p${nproc} compile"
    },
    "dependencies": {
        "ws": "^8.21.0",
        "socks": "^2.8.9",
        "colors": "^1.4.0",
        "cmake-js": "^8.0.0",
        "proxy-agent": "^8.0.2",
        "node-addon-api": "^8.9.0",
        "systeminformation": "^5.31.17"
    },
    "devDependencies": {
        "@types/ws": "^8.18.1",
        "typescript": "^7.0.2",
        "@types/node": "^26.1.1"
    },
    "engines": {
        "node": ">=22.0.0"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/dev-swarup/NMiner.git"
    },
    "license": "BSD-3-Clause",
    "author": "Swarup Banerjee",
    "bugs": {
        "url": "https://github.com/dev-swarup/NMiner/issues"
    },
    "homepage": "https://github.com/dev-swarup/NMiner#readme",
    "files": [
        "LICENSE",
        "index.js",
        "bin/*.node",
        "index.d.ts",
        "src/js/*.js",
        "src/js/*.d.ts"
    ]
}